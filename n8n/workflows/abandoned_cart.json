{
  "name": "Abandoned Cart Recovery",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "mushroombox-abandoned-cart",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [ 250, 300 ]
    },
    {
      "parameters": {
        "toEmail": "={{$json.body.customer_email}}",
        "subject": "You left something in your mushroom basket 🍄",
        "html": "We saved your cart. Click here to complete your checkout!"
      },
      "name": "Send Recovery Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [ 450, 300 ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [ { "node": "Send Recovery Email", "type": "main", "index": 0 } ]
      ]
    }
  },
  "active": false
}
